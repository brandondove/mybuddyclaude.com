{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{
					"slug": "base",
					"color": "#FAFAF7",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#16140F",
					"name": "Contrast"
				},
				{
					"slug": "accent",
					"color": "#E8450A",
					"name": "Accent"
				},
				{
					"slug": "accent-light",
					"color": "#FDF0EA",
					"name": "Accent Light"
				},
				{
					"slug": "surface",
					"color": "#F2EFE9",
					"name": "Surface"
				},
				{
					"slug": "muted",
					"color": "#766D65",
					"name": "Muted"
				},
				{
					"slug": "border",
					"color": "#E0DAD3",
					"name": "Border"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "White"
				},
				{
					"slug": "ink",
					"color": "#0A0906",
					"name": "Ink"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Fraunces, Georgia, serif",
					"slug": "fraunces",
					"name": "Fraunces"
				},
				{
					"fontFamily": "'Plus Jakarta Sans', system-ui, -apple-system, sans-serif",
					"slug": "jakarta",
					"name": "Plus Jakarta Sans"
				},
				{
					"fontFamily": "'JetBrains Mono', 'Fira Code', Consolas, monospace",
					"slug": "mono",
					"name": "JetBrains Mono"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.75rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "base",
					"size": "1rem",
					"name": "Base"
				},
				{
					"slug": "md",
					"size": "1.125rem",
					"name": "Medium"
				},
				{
					"slug": "lg",
					"size": "1.375rem",
					"name": "Large"
				},
				{
					"slug": "xl",
					"size": "1.75rem",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "2.25rem",
					"name": "2XL"
				},
				{
					"slug": "3xl",
					"size": "3rem",
					"name": "3XL"
				},
				{
					"slug": "4xl",
					"size": "4rem",
					"name": "4XL"
				},
				{
					"slug": "display",
					"size": "clamp(3rem, 6vw, 5.5rem)",
					"name": "Display"
				}
			],
			"lineHeight": true,
			"letterSpacing": true,
			"textTransform": true
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{ "slug": "10", "size": "0.5rem",  "name": "XS" },
				{ "slug": "20", "size": "1rem",    "name": "Small" },
				{ "slug": "30", "size": "1.5rem",  "name": "Medium" },
				{ "slug": "40", "size": "2.5rem",  "name": "Large" },
				{ "slug": "50", "size": "4rem",    "name": "XL" },
				{ "slug": "60", "size": "6rem",    "name": "2XL" },
				{ "slug": "70", "size": "9rem",    "name": "3XL" }
			],
			"padding": true,
			"margin": true,
			"units": ["px", "em", "rem", "%", "vw", "vh"]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"presets": [
				{
					"slug": "soft",
					"shadow": "0 1px 3px rgba(22,20,15,0.06), 0 4px 16px rgba(22,20,15,0.08)",
					"name": "Soft"
				},
				{
					"slug": "medium",
					"shadow": "0 4px 12px rgba(22,20,15,0.10), 0 12px 40px rgba(22,20,15,0.12)",
					"name": "Medium"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--jakarta)",
			"fontSize": "var(--wp--preset--font-size--md)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--4xl)",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--3xl)",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.02em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontWeight": "600",
					"lineHeight": "1.2",
					"letterSpacing": "-0.01em"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--base)",
					"fontWeight": "700",
					"lineHeight": "1.4",
					"letterSpacing": "0.04em",
					"textTransform": "uppercase"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "700",
					"lineHeight": "1.4",
					"letterSpacing": "0.06em",
					"textTransform": "uppercase"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "600",
					"letterSpacing": "0.02em"
				},
				"border": {
					"radius": "6px"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"bottom": "0.75rem",
						"left": "1.5rem",
						"right": "1.5rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "700",
					"letterSpacing": "-0.01em"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "#7EE787"
				},
				"spacing": {
					"padding": {
						"top": "1.25rem",
						"bottom": "1.25rem",
						"left": "1.5rem",
						"right": "1.5rem"
					}
				},
				"border": {
					"radius": "8px"
				}
			},
			"core/preformatted": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "#7EE787"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--xl)",
					"lineHeight": "1.3"
				},
				"border": {
					"color": "var(--wp--preset--color--accent)",
					"width": "3px"
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontStyle": "italic"
				},
				"border": {
					"color": "var(--wp--preset--color--accent)",
					"width": "3px",
					"style": "solid"
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "blank",
			"title": "Blank",
			"postTypes": ["page", "post"]
		},
		{
			"name": "page-no-title",
			"title": "Page (No Title)",
			"postTypes": ["page"]
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"patterns": []
}
